{
    "name": "rkn/cms",
    "description": "Flat-file CMS for shared hosting — Markdown, Twig, Yoyo reactive components, PSR-7/11/15/16, no database required.",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "cms", "flat-file", "markdown", "twig", "yoyo",
        "psr-7", "psr-16", "shared-hosting", "cpanel", "plesk",
        "htmx", "php", "reactive-components"
    ],
    "homepage": "https://rakuncms.com",
    "authors": [
        {
            "name": "Rakun Ventures",
            "homepage": "https://rakun.mx",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/RakunVentures/rakuncms/issues",
        "source": "https://github.com/RakunVentures/rakuncms",
        "docs": "https://rakuncms.com/docs"
    },
    "autoload": {
        "psr-4": {
            "Rkn\\": "src/"
        },
        "files": ["src/Framework/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": ["bin/rakun"],
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "laminas/laminas-httphandlerrunner": "^2.10",
        "nikic/fast-route": "^1.3",
        "twig/twig": "^3.8",
        "clickfwd/yoyo": "^0.14",
        "league/commonmark": "^2.8",
        "spatie/yaml-front-matter": "^2.1",
        "phpmailer/phpmailer": "^6.9",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "psr/container": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse src/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
